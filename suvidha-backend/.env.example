# Copy this file to .env and fill in real values before running

# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/suvidha?schema=public"

# Used to sign JWT access & refresh tokens - use a long random string in production
JWT_ACCESS_SECRET="replace-with-a-long-random-string"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-string"

# Token lifetimes
ACCESS_TOKEN_EXPIRY="15m"
REFRESH_TOKEN_EXPIRY="7d"

PORT=4000

# AI compliance assistant (Milestone 6) - get a key from console.anthropic.com
ANTHROPIC_API_KEY="your-api-key-here"
ANTHROPIC_MODEL="claude-sonnet-4-5"

# ---- Milestone 7 ----

# Used to encrypt Zoho Books / QuickBooks OAuth tokens at rest (AES-256-GCM).
# Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY="replace-with-a-32-byte-hex-key"

# Zoho Books OAuth app - register one at https://api-console.zoho.in
ZOHO_CLIENT_ID=""
ZOHO_CLIENT_SECRET=""
ZOHO_REDIRECT_URI="http://localhost:4000/businesses/integrations/zoho/callback"

# QuickBooks OAuth app - register one at https://developer.intuit.com
QUICKBOOKS_CLIENT_ID=""
QUICKBOOKS_CLIENT_SECRET=""
QUICKBOOKS_REDIRECT_URI="http://localhost:4000/businesses/integrations/quickbooks/callback"

# Where to redirect the browser back to after a successful OAuth connection
FRONTEND_URL="http://localhost:3000"

# Email (SMTP) - the notification service currently just logs messages
# (see src/services/notification.service.ts) - wire in a real provider like
# SendGrid before real use:
SENDGRID_API_KEY=""

# SMS / WhatsApp (Twilio) - same story, stubbed until these are filled in:
TWILIO_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_SMS_FROM=""
